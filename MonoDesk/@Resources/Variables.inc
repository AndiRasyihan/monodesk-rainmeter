[Variables]
; ===== MonoDesk - variabel global (dipakai semua skin) =====
; Ubah warna/font/aplikasi di sini, semua skin ikut berubah.
; PENTING: satu pengaturan per baris, jangan digabung!
FontName=Segoe UI
FontColor=255,255,255
FontColorDim=255,255,255,150
BoxColor=8,8,8,210
BoxStroke=255,255,255,230
ScrollMouseIncrement=0.02

; ===== Daftar aplikasi launcher (ganti sesuka hati) =====
; Setelah mengganti: jalankan make_icons.ps1 lalu install.bat
; Path bisa berupa: file .exe/.bat, nama pendek (chrome, winword),
; atau protokol aplikasi Store (whatsapp:)
App1Name=WhatsApp
App1Path=whatsapp:
App2Name=Chrome
App2Path=chrome
App3Name=VS Code
App3Path=C:\Users\Rasyihan's\AppData\Local\Programs\Microsoft VS Code\Code.exe
App4Name=Explorer
App4Path=explorer.exe
App5Name=Word
App5Path=winword
App6Name=Buka Semua
App6Path=C:\Users\Rasyihan's\Documents\gabut\BukaAplikasi.bat
